# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files you want to always be normalized and converted to native formats on checkins
*.py text diff=python
*.md text
*.yml text
*.yaml text
*.txt text
*.html text

# Declare files that will definitely be binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.svgz binary

# Dockerfiles should use LF
Dockerfile text eol=lf
docker-compose.yml text eol=lf
